filter_15min_intervals <- function(df) {
df %>%
mutate(time_diff = as.numeric(difftime(lead(dateTime), dateTime, units = "mins"))) %>%
filter(time_diff == 15) %>%
mutate(flow_diff = lead(Flow_Inst) - Flow_Inst)
}
